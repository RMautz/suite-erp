NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key de `pnpm supabase start`>
NEXT_PUBLIC_URL_ERP=http://localhost:3001
# En producción con dominio propio: NEXT_PUBLIC_COOKIE_DOMAIN=.tudominio.cl
NEXT_PUBLIC_COOKIE_DOMAIN=
# Redirección del login para admins de plataforma (misma lista que apps/admin)
NEXT_PUBLIC_URL_ADMIN=
ADMIN_EMAILS=

# ============ Aviso de tickets (spec tickets 2026-07-22) ============
# Correo al ADMIN de plataforma cuando un tenant crea un ticket en /consultas.
# Best-effort: sin configurar, el ticket igual se crea (solo no llega el aviso).
# Destino: la primera entrada de ADMIN_EMAILS. 'mock' -> visor /mock-correo del erp.
PROVEEDOR_CORREO=mock            # mock | resend (ausente u otro valor = sin aviso)
RESEND_API_KEY=
CORREO_REMITENTE=

# Acceso al chat del bot desde /consultas (ver apps/erp/.env.example).
NEXT_PUBLIC_WHATSAPP_URL=http://localhost:3001/mock-whatsapp

# ============ Avisos al WhatsApp del admin (spec avisos 2026-07-24) ============
# Best-effort junto al correo. En produccion real exige plantillas HSM (credencial #15).
PROVEEDOR_WHATSAPP=mock          # mock | cloud
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ADMIN=                  # E.164 del admin, ej +56912345678 (vacio = sin aviso WA)
