NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key de `pnpm supabase start`>
NEXT_PUBLIC_URL_WEB=http://localhost:3000
NEXT_PUBLIC_COOKIE_DOMAIN=

# Clave AES-256 (32 bytes hex) para cifrar el certificado DTE. Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DTE_ENCRYPTION_KEY=
DTE_AMBIENTE=certificacion

# Pasarela de pagos: 'mock' (default, sin credenciales reales) o 'mercadopago'.
PASARELA_PAGOS=mock
